# .claude/skills/delegate/scripts/.env.example
#
# Copy to $REPO_ROOT/.env (or sibling .env in this scripts/ dir) and fill
# in your MiniMax API key. Never commit the resolved .env — it's gitignored.
#
# The delegate scripts talk directly to MiniMax's Anthropic-compatible
# endpoint (api.minimax.io/anthropic) — no proxy process needed.

# MiniMax — platform.minimax.io
# Use either a standard key or a Coding Plan key (sk-cp-…).
MINIMAX_API_KEY=

# Optional overrides (uncomment to change defaults).
# FOUNDRY_DELEGATE_DEFAULT_MODEL=MiniMax-M2.7
# FOUNDRY_DELEGATE_ANTHROPIC_BASE=https://api.minimax.io/anthropic
# FOUNDRY_DELEGATE_OPENAI_BASE=https://api.minimax.io/v1
