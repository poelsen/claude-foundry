# tools/delegate/.env.example
#
# Copy to $REPO_ROOT/.env (or tools/delegate/.env) and fill in whichever
# providers you use. The LiteLLM proxy only needs one to be valid — the
# rest can stay unset. Never commit the resolved .env — it's gitignored.

# MiniMax direct — platform.minimax.io
MINIMAX_API_KEY=

# Moonshot (Kimi) — platform.moonshot.ai
MOONSHOT_API_KEY=

# DeepSeek direct — platform.deepseek.com
DEEPSEEK_API_KEY=

# OpenRouter — openrouter.ai (aggregator, optional; enable the
# corresponding entry in litellm.yaml if you want to route through it)
OPENROUTER_API_KEY=

# Proxy port override (default 4000). Change only if something else
# already owns 4000 on your box.
# FOUNDRY_DELEGATE_PROXY_PORT=4000

# Default model when --model is omitted. Must match a model_name in
# litellm.yaml.
# FOUNDRY_DELEGATE_DEFAULT_MODEL=MiniMax-M2
